{
  "name": "@worlds/libsql",
  "version": "0.0.1",
  "nodeModulesDir": "auto",
  "exports": {
    ".": "./src/mod.ts",
    "./quad-store": "./src/libsql/quad-store/mod.ts",
    "./search-index": "./src/libsql/search-index/mod.ts",
    "./rdfjs-store": "./src/libsql/rdfjs-store/mod.ts",
    "./schema": "./src/libsql/schema/libsql-schema-builder.ts"
  },
  "imports": {
    "@/": "./src/",
    "ai": "npm:ai@^6.0.195",
    "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.80",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.2.3",
    "@rdfjs/types": "npm:@rdfjs/types@^2.0.1",
    "@libsql/client": "npm:@libsql/client@^0.17.3",
    "@worlds/client": "jsr:@worlds/client@0.0.17",
    "@worlds/client/quad-store": "jsr:@worlds/client@0.0.17/quad-store",
    "@worlds/client/search-index": "jsr:@worlds/client@0.0.17/search-index",
    "@worlds/client/search-index/embedding-service": "jsr:@worlds/client@0.0.17/search-index/embedding-service",
    "@worlds/client/search-index/quad-chunker": "jsr:@worlds/client@0.0.17/search-index/quad-chunker",
    "@worlds/client/adapters/comunica": "jsr:@worlds/client@0.0.17/adapters/comunica",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/async": "jsr:@std/async@^1.4.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@tensorflow/tfjs": "npm:@tensorflow/tfjs@^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "npm:@tensorflow/tfjs-backend-wasm@^4.22.0",
    "@types/n3": "npm:@types/n3@1.26.1",
    "n3": "npm:n3@^2.0.3",
    "rdf-canonize": "npm:rdf-canonize@^5.0.0",
    "@langchain/core": "npm:@langchain/core@^1.1.48",
    "@langchain/textsplitters": "npm:@langchain/textsplitters@^1.0.1",
    "zod": "npm:zod@^4.4.3"
  },
  "links": [
    "./vendor/jsonld-context-parser"
  ],
  "exclude": [
    "vendor/jsonld-context-parser/**"
  ],
  "tasks": {
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check",
    "test": "deno test --allow-all",
    "publish:dry": "deno publish --dry-run --allow-dirty",
    "ci": {
      "description": "Formats, lints, checks, and tests the code",
      "dependencies": [
        "fmt:check",
        "lint",
        "check",
        "test"
      ]
    }
  }
}
